# スタッフ台帳・訪問予定（個人情報・住所）
data/staff/*
!data/staff/README.md
!data/staff/_template/
!data/staff/_template/**

data/schedule/*
!data/schedule/README.md
!data/schedule/_template/
!data/schedule/_template/**

# 請求・LINEリスト（個人情報）
data/billing/*
